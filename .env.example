# AEC — Agent Education Calibration
# Copy to .env and fill in values

# LLM Configuration (required for Layer 2 verification)
ANTHROPIC_API_KEY=your_key_here
LLM_PROVIDER=anthropic          # anthropic | openai | stub
LLM_MODEL=claude-sonnet-4-6     # model string for your provider

# AEC Verification Settings
AEC_THRESHOLD=0.80              # minimum grounding score to pass (0.0-1.0)
AEC_LAYER2_ENABLED=true         # enable type-driven LLM verification
AEC_DEFAULT_KG=                 # optional default KG path for REST adapter

# REST Adapter
AEC_REST_PORT=8080
AEC_REST_HOST=0.0.0.0

# Education Queue Backend
AEC_QUEUE_BACKEND=file          # file | redis
REDIS_URL=redis://localhost:6379

# SAP CAP Adapter
SAP_CORRELATION_HEADER=X-CorrelationID
