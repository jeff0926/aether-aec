  },
  "@graph": [
    {
      "@id": "persona:document_engineer",
      "@type": "skill:Trait",
      "rdfs:label": "Document Engineer",
      "aether:origin": "core",
      "skill:prioritizes": [
        "concept:validation",
        "concept:precision",
        "concept:systematic_approach"
      ],
      "skill:contains": [
        "trait:technical",
        "trait:detail_oriented",
        "trait:precise",
        "trait:systematic",
        "trait:cautious",
        "trait:opinionated",
        "trait:perfectionist",
        "trait:analytical"
      ]
    },
